# Copy to .streamlit/secrets.toml locally, OR set these in the Streamlit
# Community Cloud dashboard (Settings -> Secrets). NEVER commit real secrets.
# (This template is safe to commit; .streamlit/secrets.toml itself is gitignored.)

NEO4J_URI = "neo4j+s://<your-aura-id>.databases.neo4j.io"
NEO4J_USER = "<aura-username>"
NEO4J_PASSWORD = "<aura-password>"

CEREBRAS_API_KEY = "csk-..."
CEREBRAS_BASE_URL = "https://api.cerebras.ai/v1"
CEREBRAS_MODEL = "gpt-oss-120b"
